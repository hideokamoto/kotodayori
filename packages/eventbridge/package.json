{
  "name": "@kotodayori/eventbridge",
  "version": "1.0.3",
  "description": "AWS EventBridge adapter for Kotodayori Webhook Router",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@kotodayori/core": "workspace:^"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.162",
    "tsup": "^8.5.1",
    "typescript": "^6.0.0",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "webhook",
    "router",
    "eventbridge",
    "aws",
    "typescript"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hideokamoto/stripe-webhook-router"
  },
  "homepage": "https://github.com/hideokamoto/stripe-webhook-router#readme",
  "bugs": "https://github.com/hideokamoto/stripe-webhook-router/issues"
}
