{
  "name": "create-kotodayori",
  "version": "1.1.1",
  "description": "Scaffolding tool for Kotodayori webhook handlers",
  "type": "module",
  "bin": {
    "create-kotodayori": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "sync:skill": "node scripts/sync-skill.mjs",
    "prebuild": "node scripts/sync-skill.mjs",
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cac": "^7.0.0",
    "execa": "^9.0.0",
    "ora": "^9.0.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "@types/prompts": "^2.4.9",
    "@vitest/coverage-v8": "^4.1.8",
    "tsup": "^8.5.1",
    "typescript": "^6.0.0",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "kotodayori",
    "stripe",
    "webhook",
    "scaffolding",
    "cli",
    "create"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hideokamoto/stripe-webhook-router"
  },
  "homepage": "https://github.com/hideokamoto/stripe-webhook-router#readme",
  "bugs": "https://github.com/hideokamoto/stripe-webhook-router/issues"
}
